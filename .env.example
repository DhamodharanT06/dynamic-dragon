# Email Configuration for Support Feature
# Copy this file to .env.local and fill in your email credentials

# Email service (gmail, outlook, etc.)
EMAIL_SERVICE=gmail

# Your email address (the one sending emails)
EMAIL_USER=your-email@gmail.com

# App-specific password (for Gmail, use: https://myaccount.google.com/apppasswords)
# For Gmail: Enable 2FA, then generate an App Password
# For other services: Use your regular password or app-specific password
EMAIL_PASSWORD=your-app-specific-password

# Where support form emails should be delivered
EMAIL_TO=your-support-inbox@gmail.com

# Optional sender override shown in inbox
# EMAIL_FROM="Dynamic Dragon Support <your-email@gmail.com>"

# Optional SMTP mode (use this instead of EMAIL_SERVICE if needed)
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_SECURE=false
