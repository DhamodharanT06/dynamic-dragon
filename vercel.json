{
  "version": 2,
  "name": "dynamic-dragon-landing",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/data/(.*)", "dest": "/data/$1" },
    { "src": "/app-ads.txt", "dest": "/app-ads.txt" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
